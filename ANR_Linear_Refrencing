    def remove_columns(self,field):   
        """
        Removes all fields from a feature class except those specified.
        
        Parameters
        ----------
        feature_class : str
            Path to the feature class or table.
        fields_to_keep : list
            List of field names to retain.
        """
        #resets the layer each time 
        self.clean()
        # ArcGIS-required fields that cannot be deleted
        required_fields = ["OBJECTID","ANRDIST","RoadName","unique_road","SegmentID", "RoadID", "POLYID", "NAME", "length",field]
        # Combine user-specified fields with required fields
        keep = {f.upper() for f in field}
        keep.update(field.upper() for field in required_fields)
        
        # Identify deletable fields
        delete_fields = []
        
        for field in arcpy.ListFields(self.joined_routes):
            if not field.required and field.name.upper() not in keep:
                delete_fields.append(field.name)
        
        # Delete unwanted fields
        if delete_fields:
            arcpy.management.DeleteField(self.joined_routes, delete_fields)
            print(f"Deleted {len(delete_fields)} fields.")
            return self.joined_routes
        else:
            print("No fields to delete.")
  
    def LR(self):
        '''
        performs ArcPy linear refrencing tools until an event table is created 
        '''
        #check for m values
        #performs LR and returns and event table 
        arcpy.env.overwriteOutput = True
        existing_fields = [f.name for f in arcpy.ListFields(self.keep)]
        with arcpy.da.UpdateCursor(self.keep,
            ["RoadID","unique_road"]) as cursor:
            for row in cursor:
                if row[0]: 
                    row[1] = row[0].rsplit("-", 2)[0]
                    
                else:
                # Optional: Handle what happens if RoadID is missing
                    row[1] = None  # or leave it blank
                cursor.updateRow(row)
        arcpy.lr.CreateRoutes(self.keep, "unique_road", self.lr_routes, "LENGTH")  
        arcpy.lr.LocateFeaturesAlongRoutes(self.keep, self.lr_routes,
                                   "unique_road", "0.5 Feet", "event_table",
                                   "unique_road LINE FROM_M TO_M")
        arcpy.conversion.TableToExcel(
            Input_Table="event_table",
            Output_Excel_File=r"event_table1") #path would need to be changed
        print(arcpy.GetMessages())
    
