        #needs to be a layer, not feature class to work 
        arcpy.management.MakeFeatureLayer(self.joined_routes, "joined_routes_lyr")
      
        #look at returned layer 
        # idk if this actually exports the selected features 
        self.joined_routes =  arcpy.management.CopyFeatures("joined_routes_lyr",self.clean_routes)
        return self.joined_routes 

    def id_check(self,routes):
        '''
        verifies that all id's are unique

        makes two sets, 1st time it encounters an ID, it goes in seen, second time into duplicates
        if duplicates has anything in it, its length is not zero and thus is false 
        '''
        seen = set()
        duplicates = set()
        
        with arcpy.da.SearchCursor(routes, ["RoadID"]) as cursor:
            for (rid,) in cursor:
                if rid in seen:
                    duplicates.add(rid)
                else:
                    seen.add(rid)
        
        return len(duplicates) == 0
                        
                    
