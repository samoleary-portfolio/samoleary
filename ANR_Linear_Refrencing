    def clean(self):
        '''
        merges routes and ensures analysis is only being done on state roads
        yields the unique combination of travel routes and REI segments 

        '''
        #should yield the unique combination of the travel routes and rei segments 

        #getting rid of global ID 
        
        field_map = arcpy.FieldMappings()
        field_map.addTable(self.travel_routes)
                
        rem_fields = "GlOBALID"
        
        field_index = field_map.findFieldMapIndex(rem_fields)
        field_map.removeFieldMap(field_index)
        arcpy.conversion.ExportFeatures(self.travel_routes, "routes_no_id", field_mapping = field_map)
        
        arcpy.management.Merge(
                ["routes_no_id", self.rei_segments],
                self.joined_routes
            )
            
        print(arcpy.GetMessages())
            
        if not arcpy.Exists(self.joined_routes):
            raise Exception("Merge failed — joined_routes was not created")
        #standardize variables as well, eg all layers use the same thing for segment id, etc
        
        #needs to be a layer, not feature class in order to work 
        arcpy.management.MakeFeatureLayer(self.joined_routes, "joined_routes_lyr")
      
        #look at returned layer 
        # idk if this actually exports the selected features 
        self.joined_routes =  arcpy.management.CopyFeatures("joined_routes_lyr",self.clean_routes)
        #self.joined_routes = "dist1_roads"
        return self.joined_routes 
                        
                    
