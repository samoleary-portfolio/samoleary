        '''
        existing_fields = [f.name for f in arcpy.ListFields(self.joined_routes)]
        arcpy.management.AddField(self.joined_routes, "RoadID", "TEXT")

        names = set()
        count = 0
        seg_count = 1
        # do join spatial, add parcel ID combonend
        if parcel_id not in existing_fields: #check parcel_id, could be(and probably is) a different name in actuality 
            arcpy.analysis.SpatialJoin(self.joined_routes, self.state_lands, self.joined_routes, "JOIN_ONE_TO_ONE","INTERSECTS",
            field_mapping = (field_counts = 1, fields = "parcel_id"))
        with arcpy.da.UpdateCursor(self.joined_routes,
                ["ANRDIST","RoadName","SegmentID", "RoadID", "parcel_id"]) as cursor:
            for row in cursor:
                #index the road name with no spaces, store as string in road_num
                #transform segemnt id into string 
