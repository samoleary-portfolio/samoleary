                #create full id
                full_id = f"{dist_dig}-{parcel_id}-{road_str}-{seg_str}"
                if full_id in names:
                    count += 1
                    road_str = f"{road_str}-{count}"
                    full_id = f"{dist_dig}-{parcel_id}-{road_str}-{seg_str}"
                    row[3] = full_id
                else:
                    names.add(full_id)
                    row[3] = full_id
                cursor.updateRow(row)   
            
