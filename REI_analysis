    def score_to_num(self, feature_c, cat_field, num_field="CAT_NUM", category_map=None):
        """
        Converts a categorical text field into a numeric field (1-4) in a feature class or table.
    
        Parameters:
            feature_class (str): Path to the feature class or table.
            cat_field (str): Name of the existing categorical field (text).
            num_field (str): Name of the new numeric field to create/populate.
            category_map (dict): Optional explicit mapping, e.g. {"Low": 1, "Medium": 2, "High": 3, "Extreme": 4}.
                                  If None, categories are auto-mapped in the order they're first encountered.
    
        Returns:
            dict: The category-to-number mapping that was used.
        """
    
        # Add the numeric field if it doesn't already exist
        existing_fields = [f.name for f in arcpy.ListFields(feature_c)]
        if num_field not in existing_fields:
            arcpy.management.AddField(feature_c, num_field, "SHORT",field_is_nullable="NULLABLE")
    
        # Build the mapping if not provided
        if category_map is None:
            categories = []
            with arcpy.da.SearchCursor(feature_c, [cat_field]) as cursor:
                for row in cursor:
                    val = row[0]
                    if val is not None and val not in categories:
                        categories.append(val)
            category_map = {cat: i + 1 for i, cat in enumerate(categories)}
    
        # Update rows with the mapped numeric value
        with arcpy.da.UpdateCursor(feature_c, [cat_field, num_field]) as cursor:
            for row in cursor:
                cat_val = row[0]
                row[1] = category_map.get(cat_val)  # None if category not found
                cursor.updateRow(row)

        return category_map
    def prep(self):
        '''
        preps data for analysis 
        1. spatial join with crossings 
        2. spatial join wiht road ids
        3. convert segment score to a number 
        '''
        # spatial join with crossings, may need to be a normal join 
       # arcpy.analysis.SpatialJoin(self.rei_segments, join_features, out_feature_class, {join_operation}, {join_type}
        # spatial join with road ids
        #need field mappings to just add Road ID
        field_mappings = arcpy.FieldMappings()
        field_mappings.addTable(self.clean_routes)
        field_mappings.addTable(self.rei_segments)
        # Fields you want to keep from join layer
        keep_fields = ["RoadID"]
        
        # Loop backwards so removal is safe
        for i in reversed(range(field_mappings.fieldCount)):
            fmap = field_mappings.getFieldMap(i)
            field_name = fmap.outputField.name
        
            # If field comes from join layer AND is not wanted → remove it
            if field_name not in keep_fields:
                # Check if it's NOT from target layer
                if field_name not in [f.name for f in arcpy.ListFields(self.rei_segments)]:
                    field_mappings.removeFieldMap(i)
        fc = r"C:\Users\soleary\Documents\ArcGIS\Projects\REI_analysis\REI_analysis.gdb\rei_id"
        arcpy.analysis.SpatialJoin(
            target_features=self.rei_segments,
            join_features=self.clean_routes,
            out_feature_class=fc,
            join_operation="JOIN_ONE_TO_MANY",
            join_type="KEEP_ALL",  # optional but recommended
            field_mapping=field_mappings,
            match_option="INTERSECTS"
        )        
        self.rei_segments = fc #rei segments with requisite roadid's 
        self.score_to_num(self.rei_segments, "SegmentScore", num_field="SegScore", category_map= {"Does Not Meet":1,"Partially Meets": 2, "Fully Meets":3,"No Score": None, "Not Connected":None})
        self.score_to_num(self.rei_segments, "CrownScore", num_field="CrownScr", category_map= {"Does Not Meet":1,"Partially Meets": 2, "Fully Meets":3,"No Score": None, "Not Connected":None})
        self.score_to_num(self.rei_segments, "DrainScore", num_field="DrainScr", category_map= {"Does Not Meet":1,"Partially Meets": 2, "Fully Meets":3,"No Score": None, "Not Connected":None})
        self.score_to_num(self.rei_segments, "CulvertScore", num_field="CulvertScr", category_map= {"Does Not Meet":1,"Partially Meets": 2, "Fully Meets":3,"No Score": None, "Not Connected":None})
        self.score_to_num(self.rei_segments, "CrossScore", num_field="CrossScr", category_map= {"Does Not Meet":1,"Partially Meets": 2, "Fully Meets":3,"No Score": None, "Not Connected":None})
        self.score_to_num(self.rei_segments, "BufferScore", num_field="BufferScr", category_map= {"Does Not Meet":1,"Partially Meets": 2, "Fully Meets":3,"No Score": None, "Not Connected":None})
        self.score_to_num(self.rei_segments, "SegmentPriority", num_field="SegPrior", category_map= {"Low Priority":4,"Moderate Priority": 3, "High Priority":2,"Very High Priority": 1, "N/A":None})

        
