def build_triple_set(fc, key_field, fields):
    """Returns a set of (key, field_name, value) tuples."""
    triples = set()
    all_fields = [key_field] + fields
    with arcpy.da.SearchCursor(fc, all_fields) as cursor:
        for row in cursor:
            key = row[0]
            for field, val in zip(fields, row[1:]):
                # normalize so type/format quirks don't create false diffs
                if val is None:
                    norm = None
                elif isinstance(val, float):
                    norm = round(val, 3)
                else:
                    norm = str(val).strip()
                triples.add((key, field, norm))
    return triples


